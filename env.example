# Telegram Bot Token
# 从 @BotFather 获取您的机器人 Token 并替换下面的值
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# OpenAI 兼容 API 配置（主要 API）
# 可用于 OpenAI / Azure / 其他兼容服务
PRIMARY_API_KEY=your_primary_api_key_here
# 可选：自定义 BaseURL（默认使用 OpenAI 官方）
PRIMARY_API_BASE_URL=https://api.openai.com/v1
PRIMARY_MODEL=gpt-4o-mini

# OpenAI 兼容 API 配置（备用 API）
FALLBACK_API_KEY=your_fallback_api_key_here
# 可选：自定义 BaseURL
FALLBACK_API_BASE_URL=https://api.openai.com/v1
FALLBACK_MODEL=gpt-4o-mini

# 管理员用户ID（可以访问 /status 和 /admin 命令）
# 多个用户ID用逗号分隔
ADMIN_USER_IDS=123456789,987654321 

# 可选配置
# 数据库文件路径（默认为 storage/messages.db）
# DATABASE_PATH=storage/messages.db

# 日志级别（debug, info, warn, error）
# LOG_LEVEL=info
